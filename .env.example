# Copy this file to .env for local development and replace placeholder values.

ACCESS_SECRET=replace-me
REFRESH_SECRET=replace-me
GMAIL_APP_PASSWORD=replace-me
GMAIL_USER=replace-me@example.com
DB_CONNECTION=mongodb://replace-me

DF_PORT=3000
AUTH_PORT=4000
VITE_API_URL=http://localhost:3000
VITE_AUTH_URL=http://localhost:4000
FRONTEND_URLS=http://localhost:8080,http://127.0.0.1:8080

BUCKET_NAME=replace-me
BUCKET_REGION=eu-north-1
BUCKET_ACCESS_KEY=replace-me
BUCKET_SECRET_ACCESS_KEY=replace-me

POSTGRES_PASSWORD=replace-me
POSTGRES_PORT_BINDING=127.0.0.1:5433:5433
PG_CONNECTION=postgresql://postgres:replace-me@postgres:5433/chatenko

# Optional discrete Postgres settings if you are not using PG_CONNECTION.
# PGHOST=localhost
# PGPORT=5433
# PGUSER=postgres
# PGPASSWORD=replace-me
# PGDATABASE=chatenko
